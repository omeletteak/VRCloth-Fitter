# This file is generated by the Gemini CLI.
# Based on the standard Unity .gitignore template.

# Unity-generated files and folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
/[Mm]emoryCaptures/

# Asset meta files should only be ignored when the asset is also ignored.
# Otherwise, they should be committed.
!/[Aa]ssets/**/*.meta

# Test assets
/Assets/Scenes/
/Assets/Scenes.meta
/Assets/TestAvatars/
/Assets/TestAvatars.meta
/Assets/TestCloths/
/Assets/TestCloths.meta
/Assets/XR/
/Assets/XR.meta

# Logs and temporary files
*.zip
/vpm-listing-temp/

# VRCloth-Declipper dev run logs (opt-in, local-only, never distributed — No Cache)
/vrcloth-declipper-runs.jsonl
/vrcloth-declipper-log*.json
/vrcloth-body-measurements.jsonl

# VPM packages / dependencies

# Autogenerated project files
.vs/
.vscode/
*.code-workspace
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.log
crash.dmp
error.log
crash.log

# Builds
*.apk
*.aab
*.unitypackage

# Gradle cache
.gradle/

# Rider
.idea/

# Build scripts
*.bat
/Memos/

# VPM-managed packages — restore with ALCOM/VCC or `vrc-get resolve`.
# Only the manifests at Packages/ root stay tracked; the package
# contents (VRChat SDK etc.) must never be committed (redistribution
# is prohibited by their licenses).
/Packages/*/

# Unity editor log accidentally committed at the root
/Editor.log
