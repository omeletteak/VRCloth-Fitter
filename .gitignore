# This file is generated by the Gemini CLI.
# Based on the standard Unity .gitignore template.

# Unity-generated files and folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
/[Mm]emoryCaptures/

# Asset meta files should only be ignored when the asset is also ignored.
# Otherwise, they should be committed.
!/[Aa]ssets/**/*.meta

# Test assets
/Assets/Scenes/
/Assets/Scenes.meta
/Assets/TestAvatars/
/Assets/TestAvatars.meta
/Assets/TestCloths/
/Assets/TestCloths.meta
/Assets/XR/
/Assets/XR.meta

# Logs and temporary files
/[Ee]ditor.log
/[Ee]ditor.log.meta
*.zip
/vpm-listing-temp/

# VPM packages / dependencies
/Packages/com.vrchat.avatars/
/Packages/com.vrchat.base/
/Packages/jp.lilxyzw.liltoon/
/Packages/nadena.dev.modular-avatar/
/Packages/nadena.dev.ndmf/

